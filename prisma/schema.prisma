// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

//Prisma is an ORM (object relational mapping) helps to create relational database easier

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//Defining the recipe table
//@default means it autp generates upon creation and uuid is just 
//to generate a unique code
//@id means primary key @relation means foreign key 

model Recipe {
  id            String    @id   @default(uuid())
  title         String    
  description   String?
  photoUrl      String? 
  difficulty    String
  totalMinutes  Int
  servings      Int
  ingredients   Ingredient[]
  tools         String[]
  steps         Step[]  
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String
}

model Ingredient {
  id            String    @id   @default(uuid())
  name          String
  quantity      Float
  unit          String
  recipe        Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId      String
}

model Step {
  id            String    @id   @default(uuid())
  stepNumber    Int
  instruction   String
  recipe        Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  recipeId      String
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String    
  recipes   Recipe[]
  createdAt DateTime  @default(now())
}


